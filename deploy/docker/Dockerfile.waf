FROM golang:1.22-alpine AS builder
WORKDIR /src
COPY go.mod go.sum* ./
RUN go mod download
COPY . .
RUN CGO_ENABLED=0 go build -o /waf ./cmd/waf && \
    go build -o /setup ./cmd/setup && \
    go build -o /cli ./cmd/cli

FROM alpine:3.19
WORKDIR /app
COPY --from=builder /waf /setup /cli /usr/local/bin/
COPY configs /app/configs/
COPY web /app/web/
EXPOSE 8080 9090
ENTRYPOINT ["waf"]
